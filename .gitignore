# =========================
# OS / editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Node / frontend
# =========================
apps/frontend/node_modules/
apps/frontend/dist/
apps/frontend/build/
apps/frontend/coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Java / Gradle / backend
# =========================
apps/backend/.gradle/
apps/backend/build/
apps/backend/out/
*.class

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.python-version

# =========================
# Environment / secrets
# =========================
.env
.env.*
*.env
!.env.example
!**/.env.example

# =========================
# AI artifacts / model files
# =========================
# artifacts 아래에서는 checkpoints 폴더만 구조상 유지
apps/ai-service/artifacts/*
!apps/ai-service/artifacts/checkpoints/

# checkpoints 안에서는 json 메타데이터만 추적
apps/ai-service/artifacts/checkpoints/*
!apps/ai-service/artifacts/checkpoints/.gitkeep
!apps/ai-service/artifacts/checkpoints/*.json

# 모델 바이너리 파일은 항상 무시
apps/ai-service/**/*.pt
apps/ai-service/**/*.pth
apps/ai-service/**/*.ckpt
apps/ai-service/**/*.onnx

# =========================
# Runtime shared files
# =========================
shared/uploads/*
shared/generated/*

!shared/uploads/.gitkeep
!shared/generated/.gitkeep

# =========================
# Logs / temp
# =========================
*.log
tmp/
temp/